.content
    .section
        position: relative;
        z-index: 1;

    .main
        background-color: #0D0048;
        color: #EDEBF8;
        height: 720px;

        .wave-top
            position: absolute;
            top: -155px;
            z-index: 0;

        .title
            position: absolute;
            max-width: 740px;
            font-size: 24px;
            line-height: 26px;
            margin-top: 200px;
            text-align: center;
        
        &::before
            content: ' ';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('@/assets/svg/home_background.svg');
            background-repeat: no-repeat;
            background-size: contain;
            background-blend-mode: multiply;
            z-index: -1;
        
        .waves
            position: absolute;
            bottom: 0px;
            right: 0px;

            .wave-1
                animation: wave-1 linear 5s infinite;
            
            @keyframes wave-1
                0%
                    transform: translateX(0%);
                50%
                    transform: translate(-5%, 0%);
            
            .wave-2
                animation: wave-2 linear 5s infinite;
            
            @keyframes wave-2
                0%
                    transform: translateX(0%);
                50%
                    transform: translate(10%, -10%);

            .wave-3
                animation: wave-3 linear 5s infinite;

            @keyframes wave-3
                0%
                    transform: translateX(0%);
                50%
                    transform: translate(10%, -10%);
        
        .contact-button
            position: absolute;
            top: 360px;
            display: flex;
            justify-content: center;
            width: 100%;

            a
                display: inline-block;
                width: 254px;
                padding: 13px;
                border-radius: 10px;
                background-color: #0095A9;
                text-align: center;
                font-size: 14px;
                line-height: 21px;
                color: #FFFFFF;
                text-decoration: none;
        
        @media screen and (min-width: 768px)
            height: 796px;

            .title
                margin-left: 60px;
        
        @media screen and (min-width: 900px)
            .title
                font-size: 60px;
                line-height: 66px;
                text-align: left;
                margin-left: 115px;
            
        @media screen and (min-width: 1024px)
            .contact-button
                display: none;
    
    .meet-studio
        display: flex;
        flex-direction: column;
        align-items: center;
        text-transform: none;
        gap: 80px;
        background-color: #EDEBF8;
        padding: 0px 23px 80px 23px;
        font-family: 'Poppins', sans-serif;

        .title
            max-width: 798px;
            font-size: 40px;
            line-height: 48px;
            text-align: center;
            margin-top: 41.5px;
            margin-bottom: 41.5px;
        
        .text
            display: flex;
            flex-direction: column;
            max-width: 1028px;
            padding-right: 40px;
            gap: 40px;

            div
                max-width: 309px;
            
            &-1
                font-size: 20px;
                line-height: 24px;
            
            &-2, &-3
                font-size: 16px;
                line-height: 20px;

        @media screen and (min-width: 768px)
            .text
                flex-direction: row;
    
    .offered-services
        display: none;
        height: 664px;
        text-transform: none;
        padding-top: 16px;
        padding-bottom: 16px;
        background: radial-gradient(174.33% 99.92% at 81.8% 51.42%, #E591EF 0.54%, #9E6CEF 100%);
        font-family: 'Poppins', sans-serif;

        .title
            text-align: center;
            font-size: 60px;
            line-height: 60px;
            margin-bottom: 45px;
        
        .container
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;

            .grid-container
                display: grid;
                grid-template-columns: repeat(5, minmax(150px, auto));
                grid-template-rows: repeat(2, 1fr);
                row-gap: 25px; /* Spacing between items */
                position: relative; /* To allow pseudo-elements if needed */
                width: 100%;

                .grid-item
                    img
                        max-width: 150px;
                        height: auto;
                        object-fit: contain;

                    figure
                        margin: 0px;
                        font-size: 16px;
                        line-height: 16px;
                        font-weight: 500;

                        figcaption
                            width: 200px;
                            margin-top: 10px;

                .grid-item.top
                    transform: translate(50px, -10px);
                
                .grid-item.bottom
                    transform: translateX(10px);
                
                .first
                    grid-column-start: 1;
                    grid-column-end: 2;
                    grid-row-start: 2;
                    grid-row-end: 3;
                
                .second
                    grid-column-start: 2;
                    grid-column-end: 3;
                    grid-row-start: 1;
                    grid-row-end: 2;
                
                .third
                    grid-column-start: 3;
                    grid-column-end: 4;
                    grid-row-start: 2;
                    grid-row-end: 3;
                
                .fourth
                    grid-column-start: 4;
                    grid-column-end: 5;
                    grid-row-start: 1;
                    grid-row-end: 2;

                .fifth
                    grid-column-start: 5;
                    grid-column-end: 6;
                    grid-row-start: 2;
                    grid-row-end: 3;
        
        @media screen and (min-width: 768px)
            display: flow;
        
        @media screen and (min-width: 900px)
            .title
                font-size: 50px;
                line-height: 60px;

            .container .grid-container
                .grid-item img
                    max-width: 100%;

                .grid-item.top
                    transform: translate(-10px, 10px);
                
                .grid-item.bottom
                    transform: none;

        @media screen and (min-width: 1024px)
            .container .grid-container .grid-item.bottom
                margin-right: 10px;
                margin-left: 10px;

        @media screen and (min-width: 1200px)
            .container .grid-container .grid-item.bottom
                margin: 0px;
                transform: translateX(50px);
    
        @media screen and (min-width: 1450px)
            .container .grid-container .grid-item.bottom
                transform: translateX(minmax(150px, auto));
        
    .mission
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #0D0048;
        padding: 31px 55px;

        .text
            font-size: 20px;
            line-height: 30px;
            text-transform: none;
            max-width: 1154px;
            color: #D9D9D9;

            .line
                position: relative;

                .line-mask
                    position: absolute;
                    top: 0;
                    right: 0;
                    background-color: #0D0048;
                    opacity: 0.8;
                    height: 100%;
                    width: 100%;
                    z-index: 2;
                    animation: maskAnimate 5s infinite linear;

                @keyframes maskAnimate
                    0%
                        width: 100%;
                    100%
                        width: 0%;

        @media screen and (min-width: 768px)
            padding: 206px 67px;

            .text
                font-size: 85px;
                line-height: 102px;

    .process-services
        text-transform: none;
        background-color: #EDEBF8;
        display: flex;
        flex-direction: column;
        gap: 80px;
        padding: 80px 23px;
        color: #1E1E1E;

        @media screen and (min-width: 768px)
            align-items: center;

        .pipeline
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            line-height: 24px;
            background: var(--radial-2, radial-gradient(174.33% 99.92% at 81.8% 51.42%, #E591EF 0.54%, #9E6CEF 100%));
            color: transparent;
            background-clip: text;
            gap: 31px;

            :deep(.separator)
                display: inline-block;
                width: 52px;
                height: 0px;
                border-bottom: 3px solid #333;
        
        @media screen and (min-width: 900px)
            .pipeline-svg
                display: none;

            .pipeline
                display: flex;

        .process
            display: flex;
            flex-direction: column;
            max-width: 699px;
            gap: 30px;
            font-family: 'Poppins', sans-serif;

            .title
                width: 100%;
                font-size: 20px;
                line-height: 24px;
                text-align: left;

            .items
                display: flex;
                flex-direction: column;
                gap: 36px;

                .column
                    display: flex;
                    flex-direction: column;
                    gap: 36px;

                    .item
                        width: 310px;
                        font-size: 16px;
                        line-height: 24px;

                        :deep(.tools)
                            display: flex;
                            flex-wrap: wrap;
                            justify-content: center;
                            gap: 10px;
                            margin-top: 15px;

                            .tool
                                min-width: 139px;
                                padding: 10px 5px
                                color: #FFFFFF;
                                text-align: center;
                    
                    .discovery
                        span
                            color: #9E6CEF;

                        :deep(.tool)
                            background-color: #9E6CEF;
                    
                    .design
                        span
                            color: #F57AAE;

                        :deep(.tool)
                            background-color: #F57AAE;
                    
                    .development
                        span
                            color: #0D0048;

                        :deep(.tool)
                            background-color: #0D0048;
                    
                    .upgrade
                        span
                            color: #0095A9;

                        :deep(.tool)
                            background-color: #0095A9;

        @media screen and (min-width: 768px)
            .process
                align-items: center;

                .items
                    flex-direction: row;
                    flex-wrap: wrap;

        .quote
            max-width: 798px;
            color: #0D0048;
            text-align: center;
            font-size: 22px;
            line-height: 26px;
        
            @media screen and (min-width: 768px)
                font-size: 40px;
                line-height: 48px;
                font-weight: 500;
        
        .services
            max-width: 1022px;
            display: flex;
            flex-direction: column;
            gap: 50px;

            .title
                font-size: 32px;
                text-align: left;

            .items
                display: flex;
                flex-direction: column;
                gap: 50px;

                .item
                    width: 200px;
                    font-size: 13px;
                    line-height: 16px;

                    .item-title
                        font-size: 19px;
                        line-height: 22.8px;
                        border-top: 1px solid #000;
                        border-bottom: 1px solid #000;
                        padding: 8px 0px 23px;
                        width: 100%;
                        display: inline-block;
                        word-wrap: break-word;
            
            .contact-button
                display: flex;
                width: 254px;
                height: 55px;
                justify-content: center;
                align-items: center;
                gap: 10px;
                border-radius: 10px;
                background: #9E6CEF;
                align-self: center;

                a
                    text-decoration: none;
                    color: #F3F3F3;
        
            @media screen and (min-width: 768px)
                align-items: center;

                .items
                    flex-direction: row;
                    flex-wrap: wrap;
    
    .quote-2
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: radial-gradient(174.33% 99.92% at 81.8% 51.42%, #E591EF 0.54%, #9E6CEF 100%);
        padding: 107px 56px;
        color: #1A1A1A;
        font-size: 20px;
        line-height: 24px;
        
        span
            max-width: 798px;

        @media screen and (min-width: 768px)
            font-size: 40px;
            line-height: 48px;
            padding: 300px 241px;
    
    .team
        padding: 80px 0px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-transform: none;
        background-color: #EDEBF8;

        .member
            display: flex;
            flex-direction: column;
            gap: 59px;
            font-family: 'Poppins', sans-serif;

            .photo img
                width: 344px;
                height: 401px;
                object-fit: cover;
                

            .profile
                padding: 23px;

                .presentation
                    width: 305px;
                    font-size: 16px;
                    line-height: 19px;
                    margin-bottom: 16px;
    
        @media screen and (min-width: 576px)
            .member
                .photo img
                    width: 532px;

                .profile
                    padding: 0px;

                    .presentation
                        width: 391px;

        @media screen and (min-width: 900px)
            .member
                flex-direction: row;
                align-items: center;
